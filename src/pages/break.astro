---
import BoredClickPanel from "@components/BoredClickPanel.svelte";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout
	title="歇一会"
	description="把之前独立的 bored-click 小互动整理进主站后的一个轻量互动角落。"
>
	<div class="space-y-4">
		<section class="card-base overflow-hidden">
			<div class="px-6 py-6 md:px-8 md:py-8">
				<p class="text-50 text-[0.72rem] font-semibold uppercase tracking-[0.28em]">
					小小游乐场
				</p>
				<h1 class="text-3xl md:text-5xl font-bold text-90 mt-3">
					到这里短暂停一下
				</h1>
				<p class="text-75 text-base md:text-lg leading-7 mt-4 max-w-2xl">
					这个页面把之前独立的 bored-click 原型整理进了主站，作为一个轻量的
					Svelte 互动岛。循环还是一样：点一下，换一句话；想换个心情，就切
					一套配色；想从头来过，随时都可以重置。
				</p>
			</div>
		</section>

		<BoredClickPanel client:only="svelte" />
	</div>
</MainGridLayout>
