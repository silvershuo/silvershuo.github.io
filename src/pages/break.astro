---
import BoredClickPanel from "@components/BoredClickPanel.svelte";
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout
	title="Break"
	description="A small interactive corner rebuilt from the standalone bored-click mini site."
>
	<div class="space-y-4">
		<section class="card-base overflow-hidden">
			<div class="px-6 py-6 md:px-8 md:py-8">
				<p class="text-50 text-[0.72rem] font-semibold uppercase tracking-[0.28em]">
					Playground
				</p>
				<h1 class="text-3xl md:text-5xl font-bold text-90 mt-3">
					A small interactive detour
				</h1>
				<p class="text-75 text-base md:text-lg leading-7 mt-4 max-w-2xl">
					This page folds the old bored-click prototype into the main site as a
					lightweight Svelte island. The loop stays intact: click for a new line,
					switch the palette when the mood changes, and reset whenever you want a
					clean slate.
				</p>
			</div>
		</section>

		<BoredClickPanel client:only="svelte" />
	</div>
</MainGridLayout>
